# Supabase connection for the Tessera demo frontend.
#
# Copy this file to `.env` and fill in your project's values:
#   cp .env.example .env
#
# Both values below are PUBLIC by design — the anon key is meant to ship in the
# browser bundle, and real security is enforced by Row-Level Security + the
# verify Edge Function, not by hiding this key. NEVER put the service_role key
# (or any sb_secret_* key) in here or anywhere committed.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
